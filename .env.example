# Required: Bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Comma-separated Telegram user IDs allowed to use the bot.
# Leave empty to allow everyone (not recommended for production).
# Tip: message @userinfobot on Telegram to find your user ID.
ALLOWED_TELEGRAM_IDS=

# Directory Claude Code operates in (default: current directory).
# Put a CLAUDE.md here to give Claude a persona or instructions.
# WORK_DIR=/path/to/your/project

# Turns before auto-compaction (default: 100)
# COMPACT_INTERVAL=100

# Timeout for claude -p subprocess in ms (default: 300000 = 5 min)
# CLAUDE_TIMEOUT=300000

# Telegram polling interval in ms (default: 2000)
# POLL_INTERVAL=2000

# Custom compaction prompt (default: English summary prompt)
# COMPACT_PROMPT="Summarize this conversation for the next session."
